DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ecommerce_ai
JWT_SECRET=change-me

# 主站自身地址
MAIN_APP_URL=https://www.qycm.top

# 外部工作台 / 子站
VIDEO_APP_URL_SEEDANCE=https://disanfang.qyaijingxuan.top
KB_CHAT_APP_URL=https://qyzsk.qyaijingxuan.top
DETAIL_IMAGE_AGENT_APP_URL=https://dianpu.qyaijingxuan.top
BUYER_SHOW_APP_URL=https://maijiaxiu.qyaijingxuan.top
COPYWRITING_AGENT_APP_URL=https://wenan.qyaijingxuan.top

# 主站与子站共享的 SSO 交换密钥（如果你的视频子站还在用）
VIDEO_SSO_INTERNAL_SECRET=change-me

# 可选：admin 初始化
ADMIN_ACCOUNT=
ADMIN_PASSWORD=
ADMIN_NICKNAME=

# Optional: long-term memory with PostgreSQL + pgvector.
# Requires frontend/prisma/user_memories.sql to be applied to DATABASE_URL.
MEMORY_ENABLED=false
MEMORY_WRITE_ENABLED=false
MEMORY_MAX_RESULTS=5
MEMORY_EMBEDDING_API_URL=https://yunwu.ai/v1/embeddings
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_API_KEY=
