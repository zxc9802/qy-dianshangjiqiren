# Database
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Auth
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_EXPIRES_IN="7d"

# AI services
AI_API_URL="https://yunwu.ai/v1beta/models/gemini-3-flash-preview:streamGenerateContent"
AI_API_KEY="your-api-key"
YUNWU_OPENAI_CHAT_API_KEY="your-openai-chat-api-key"
YUNWU_OPENAI_CHAT_URL="https://yunwu.ai/v1/chat/completions"
YUNWU_OPENAI_CHAT_MODEL="gpt-5.4"
YUNWU_IMAGE_API_URL="https://yunwu.ai/v1beta/models/gemini-3.1-flash-image-preview:generateContent"
YUNWU_IMAGE_API_KEY="your-image-api-key"
# OpenAI-compatible image endpoint. When YUNWU_IMAGE_MODEL or YUNWU_IMAGE_BASE_URL is set,
# image generation uses BASE_URL + /images/generations instead of YUNWU_IMAGE_API_URL.
YUNWU_IMAGE_BASE_URL="https://yunwu.ai/v1"
YUNWU_IMAGE_MODEL="gpt-image-2"
YUNWU_IMAGE_SIZE="1024x1024"
YUNWU_VIDEO_API_KEY="your-video-api-key"

# Voice services
VOICE_API_URL="wss://openspeech.bytedance.com/api/v3/sauc/bigmodel"
VOICE_APP_KEY="your-app-key"
VOICE_ACCESS_KEY="your-access-key"
VOICE_RESOURCE_ID="volc.bigasr.sauc.duration"

# Deployment URLs
FRONTEND_URL="https://your-frontend-domain.com,https://your-preview-domain.com"
FRONTEND_URLS=""
BACKEND_PUBLIC_URL="https://your-backend-domain.com"

# Admin bootstrap
ADMIN_ACCOUNT="admin"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_NICKNAME="Administrator"

# Runtime
PORT=3001
